---
import Base from '../layouts/Base.astro';
---

<Base>
  <div class="card">
    <div class="col-image">
      <img src="/profile.jpg" alt="Ron Diver" class="avatar" />
    </div>
    <div class="col-text">
      <h1>Ron Diver</h1>
      <p class="tagline">Absurdly curious. Relentlessly optimistic. Lucky dad.</p>
      <ul class="icons">
        <li>
          <a href="https://www.linkedin.com/in/rondiver/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://github.com/rondiver" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          </a>
        </li>
        <li>
          <a href="mailto:rondiver@gmail.com" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</Base>

<style>
  .card {
    background-image: linear-gradient(103deg, #EB816A 0%, #E6A87C 100%);
    border-radius: 0.625rem;
    box-shadow: 0 1.125rem 4.125rem 0 rgba(0, 0, 0, 0.451);
    display: flex;
    max-width: 52rem;
    width: 100%;
    overflow: hidden;
    color: #fff;
  }

  .col-image {
    flex: 0 0 40%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 3rem;
  }

  .col-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 5rem 5rem 2rem;
  }

  img.avatar {
    width: 11rem;
    height: 11rem;
    max-width: 100%;
    border-radius: 100%;
    object-fit: cover;
    display: block;
  }

  h1 {
    font-size: 2.25em;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .tagline {
    font-size: 1.125em;
    font-weight: 300;
    color: #fff;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .icons {
    list-style: none;
    display: flex;
    gap: 0.75rem;
  }

  .icons li a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5em;
    height: 2.5em;
    border-radius: 100%;
    border: solid 1px rgba(255, 255, 255, 0.459);
    color: #fff;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .icons li a:hover {
    color: #BDEAF0;
    border-color: #BDEAF0;
  }

  .icons svg {
    width: 1.1em;
    height: 1.1em;
  }

  @media (max-width: 768px) {
    .card {
      flex-direction: column-reverse;
      max-width: 28rem;
    }

    .col-image {
      padding: 3rem 3rem 2rem;
    }

    .col-text {
      padding: 3rem 2.625rem 1.5rem;
      text-align: center;
      align-items: center;
    }

    .avatar {
      width: 8rem;
      height: 8rem;
    }

    .icons {
      justify-content: center;
    }
  }
</style>

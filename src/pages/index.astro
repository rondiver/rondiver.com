---
import Base from '../layouts/Base.astro';
---

<Base>
  <main>
    <section class="hero">
      <h1>Ron Diver</h1>
      <p class="tagline">Builder, maker, and technologist.</p>
    </section>

    <section class="about">
      <p>
        I build software, websites, and businesses. Currently working on
        bookbinding, print production, and web tools in the Pacific Northwest.
      </p>
    </section>

    <section class="projects">
      <h2>Projects</h2>
      <ul>
        <li>
          <a href="https://originbooks.com" target="_blank" rel="noopener">Origin Books</a>
          <span class="desc">Custom book manufacturing</span>
        </li>
        <li>
          <a href="https://pugetbindery.com" target="_blank" rel="noopener">Puget Bindery</a>
          <span class="desc">Trade bindery services</span>
        </li>
      </ul>
    </section>

    <section class="connect">
      <h2>Connect</h2>
      <ul class="links">
        <li>
          <a href="https://github.com/rondiver" target="_blank" rel="noopener" aria-label="GitHub">
